{
  "name": "sz-match-builder-monorepo",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://DragonBallZLeague.github.io/SparkingZero",
  "workspaces": [
    "apps/matchbuilder",
    "apps/analyzer",
    "apps/calculator"
  ],
  "scripts": {
    "build": "npm run build --workspace=apps/matchbuilder",
    "build:analyzer": "npm run build --workspace=apps/analyzer",
    "build:calculator": "npm run build --workspace=apps/calculator",
    "build:all": "npm run build:analyzer && npm run build && npm run build:calculator",
    "dev": "npm run dev --workspace=apps/matchbuilder",
    "dev:analyzer": "npm run dev --workspace=apps/analyzer",
    "dev:calculator": "npm run dev --workspace=apps/calculator",
    "predeploy": "npm run build:all",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "gh-pages": "^5.0.0"
  },
  "dependencies": {
    "iconoir": "^7.11.0",
    "lucide-react": "^0.545.0",
    "vite": "^7.1.9"
  }
}
